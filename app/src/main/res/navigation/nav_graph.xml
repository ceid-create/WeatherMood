<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/navigation_login">

    <fragment
        android:id="@+id/navigation_login"
        android:name="com.charbeljoe.weathermood.ui.auth.LoginFragment"
        android:label="Login"
        tools:layout="@layout/fragment_login">
        <action
            android:id="@+id/action_login_to_home"
            app:destination="@id/navigation_home"
            app:popUpTo="@id/navigation_login"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_login_to_register"
            app:destination="@id/navigation_register" />
        <action
            android:id="@+id/action_login_to_forgot_password"
            app:destination="@id/navigation_forgot_password" />
    </fragment>

    <fragment
        android:id="@+id/navigation_forgot_password"
        android:name="com.charbeljoe.weathermood.ui.auth.ForgotPasswordFragment"
        android:label="Forgot Password"
        tools:layout="@layout/fragment_forgot_password">
        <action
            android:id="@+id/action_forgot_password_to_reset_password"
            app:destination="@id/navigation_reset_password" />
    </fragment>

    <fragment
        android:id="@+id/navigation_reset_password"
        android:name="com.charbeljoe.weathermood.ui.auth.ResetPasswordFragment"
        android:label="Reset Password"
        tools:layout="@layout/fragment_reset_password">
        <argument
            android:name="email"
            app:argType="string" />
    </fragment>

    <fragment
        android:id="@+id/navigation_register"
        android:name="com.charbeljoe.weathermood.ui.auth.RegisterFragment"
        android:label="Register"
        tools:layout="@layout/fragment_register">
        <action
            android:id="@+id/action_register_to_home"
            app:destination="@id/navigation_home"
            app:popUpTo="@id/navigation_login"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/navigation_home"
        android:name="com.charbeljoe.weathermood.ui.home.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home">
        <action
            android:id="@+id/action_home_to_place_detail"
            app:destination="@id/navigation_place_detail" />
        <action
            android:id="@+id/action_home_to_location_picker"
            app:destination="@id/navigation_location_picker" />
    </fragment>

    <fragment
        android:id="@+id/navigation_location_picker"
        android:name="com.charbeljoe.weathermood.ui.home.LocationPickerFragment"
        android:label="Pick Location"
        tools:layout="@layout/fragment_location_picker" />

    <fragment
        android:id="@+id/navigation_favorites"
        android:name="com.charbeljoe.weathermood.ui.favorites.FavoritesFragment"
        android:label="Favorites"
        tools:layout="@layout/fragment_favorites" />

    <fragment
        android:id="@+id/navigation_settings"
        android:name="com.charbeljoe.weathermood.ui.settings.SettingsFragment"
        android:label="Settings"
        tools:layout="@layout/fragment_settings" />

    <fragment
        android:id="@+id/navigation_place_detail"
        android:name="com.charbeljoe.weathermood.ui.detail.PlaceDetailFragment"
        android:label="Place Detail"
        tools:layout="@layout/fragment_place_detail">
        <argument
            android:name="placeName"
            app:argType="string" />
    </fragment>

</navigation>
